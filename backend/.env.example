# ── Supabase (required for store_sales data + PostgreSQL DB) ─────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Database (PostgreSQL dari Supabase) ───────────────────────────────────────
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@db.xxxx.supabase.co:5432/postgres

# ── HuggingFace Token (untuk Qwen LLM di /forecast/ai-insight) ───────────────
HF_TOKEN=hf_xxxxxxxxxxxx

# ── Opsional: fallback CSV path (development lokal saja) ─────────────────────
# DATASET_PATH=../dataset/store_sales.csv
